<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="collectionview.view.studentview"
             Title="studentview">
    <CollectionView ItemsSource="{Binding students}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border>
                     <StackLayout>
                           <Label Text="{Binding Name}" FontSize="Medium" FontAttributes="Bold" TextColor="White"/>
                           <Label Text="{Binding Age}" FontSize="Medium" FontAttributes="Bold" TextColor="White"/>
                     </StackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>