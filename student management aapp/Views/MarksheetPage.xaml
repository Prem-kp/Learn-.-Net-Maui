<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SchoolAppNew.Views.MarksheetPage"
             Title="Marksheet">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Online Marksheet"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#1E5E8A"/>

            <Label Text="Class XII Examination"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

            <Label Text="May 2022"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

            <Grid ColumnDefinitions="2*,1*" Padding="10" ColumnSpacing="20">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Roll Number: 3160011"/>
                    <Label Text="Student Name: Ashwin.J"/>
                    <Label Text="Regd. No: 912024104006"/>
                    <Label Text="School / Centre: School or College"/>
                    <Label Text="Father Name: Jagadeeswaran"/>
                    <Label Text="Mother Name: Muthu Selvi"/>
                    <Label Text="Date of Birth: 13 06 2006"/>
                </VerticalStackLayout>

                <Image Grid.Column="1"
                       Source="dotnet_bot.png"
                       HeightRequest="140"
                       WidthRequest="120"
                       Aspect="AspectFill"/>
            </Grid>

            <Grid ColumnDefinitions="2*,1*,1*,1*,1*" BackgroundColor="#E0E0E0" Padding="8">
                <Label Text="Subject" FontAttributes="Bold"/>
                <Label Grid.Column="1" Text="Obtained" FontAttributes="Bold"/>
                <Label Grid.Column="2" Text="Practical" FontAttributes="Bold"/>
                <Label Grid.Column="3" Text="Total" FontAttributes="Bold"/>
                <Label Grid.Column="4" Text="Grade" FontAttributes="Bold"/>
            </Grid>

            <Grid ColumnDefinitions="2*,1*,1*,1*,1*" Padding="8">
                <Label Text="Mathematics"/>
                <Label Grid.Column="1" Text="55"/>
                <Label Grid.Column="2" Text="22"/>
                <Label Grid.Column="3" Text="77"/>
                <Label Grid.Column="4" Text="B1"/>
            </Grid>

            <Grid ColumnDefinitions="2*,1*,1*,1*,1*" Padding="8">
                <Label Text="Physics"/>
                <Label Grid.Column="1" Text="61"/>
                <Label Grid.Column="2" Text="23"/>
                <Label Grid.Column="3" Text="84"/>
                <Label Grid.Column="4" Text="A2"/>
            </Grid>

            <Grid ColumnDefinitions="2*,1*,1*,1*,1*" Padding="8">
                <Label Text="Chemistry"/>
                <Label Grid.Column="1" Text="45"/>
                <Label Grid.Column="2" Text="25"/>
                <Label Grid.Column="3" Text="70"/>
                <Label Grid.Column="4" Text="B1"/>
            </Grid>

            <Grid ColumnDefinitions="2*,1*,1*,1*,1*" Padding="8">
                <Label Text="Biology"/>
                <Label Grid.Column="1" Text="65"/>
                <Label Grid.Column="2" Text="20"/>
                <Label Grid.Column="3" Text="85"/>
                <Label Grid.Column="4" Text="A2"/>
            </Grid>

            <Grid ColumnDefinitions="2*,1*,1*,1*,1*" Padding="8">
                <Label Text="Social Science"/>
                <Label Grid.Column="1" Text="67"/>
                <Label Grid.Column="2" Text="19"/>
                <Label Grid.Column="3" Text="86"/>
                <Label Grid.Column="4" Text="A2"/>
            </Grid>

            <Frame BorderColor="Gray" Padding="15" CornerRadius="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Grand Total: 402/500" FontSize="20" FontAttributes="Bold"/>
                    <Label Text="Percentage: 80.4%" FontSize="20" FontAttributes="Bold"/>
                    <Label Text="Result: Passed" FontSize="22" FontAttributes="Bold" TextColor="Green"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>