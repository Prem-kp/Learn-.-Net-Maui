<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentManagementApp.ViewModels"
             x:Class="Student_Management_App.view.Studentsdetailpage"
             Title="Students detail">
    
        <ContentPage.BindingContext>
            <vm:StudentViewModel />
        </ContentPage.BindingContext>

        <ScrollView>
            <StackLayout Padding="16" Spacing="12">

                <Label Text="Student Details"
                   FontSize="20" FontAttributes="Bold"
                   TextColor="#1565C0"
                   HorizontalOptions="Center"/>

                <!-- Student selector -->
                <Picker Title="Select Student"
                    ItemsSource="{Binding Students}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedStudent}"/>

                <!-- Detail Card -->
                <Frame BackgroundColor="White" CornerRadius="10" Padding="16"
                   HasShadow="True">

                    <StackLayout Spacing="10">
                        <Label Text="Personal Information"
                           FontAttributes="Bold" TextColor="#1565C0"/>

                        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">

                            <Label Grid.Row="0" Grid.Column="0" Text="Roll Number:"   FontAttributes="Bold"/>
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding SelectedStudent.RollNumber}"/>

                            <Label Grid.Row="1" Grid.Column="0" Text="Student Name:"  FontAttributes="Bold"/>
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding SelectedStudent.Name}"/>

                            <Label Grid.Row="2" Grid.Column="0" Text="Father Name:"   FontAttributes="Bold"/>
                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding SelectedStudent.FatherName}"/>

                            <Label Grid.Row="3" Grid.Column="0" Text="Mother Name:"   FontAttributes="Bold"/>
                            <Label Grid.Row="3" Grid.Column="1" Text="{Binding SelectedStudent.MotherName}"/>

                            <Label Grid.Row="4" Grid.Column="0" Text="Date of Birth:" FontAttributes="Bold"/>
                            <Label Grid.Row="4" Grid.Column="1" Text="{Binding SelectedStudent.DateOfBirth}"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" Margin="0,8"/>

                        <Label Text="Academic Summary"
                           FontAttributes="Bold" TextColor="#1565C0"/>

                        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                            <Label Grid.Row="0" Grid.Column="0" Text="Grand Total:"  FontAttributes="Bold"/>
                            <Label Grid.Row="0" Grid.Column="1"
                               Text="{Binding SelectedStudent.GrandTotal, StringFormat='{0}/500'}"/>

                            <Label Grid.Row="1" Grid.Column="0" Text="Percentage:"  FontAttributes="Bold"/>
                            <Label Grid.Row="1" Grid.Column="1"
                               Text="{Binding SelectedStudent.Percentage, StringFormat='{0}%'}"/>

                            <Label Grid.Row="2" Grid.Column="0" Text="Result:"      FontAttributes="Bold"/>
                            <Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding SelectedStudent.Result}"
                               TextColor="Green" FontAttributes="Bold"/>
                        </Grid>
                    </StackLayout>
                </Frame>

            </StackLayout>
        </ScrollView>
  </ContentPage>