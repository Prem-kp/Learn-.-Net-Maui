<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentManagementApp.ViewModels"
             x:Class="Student_Management_App.view.Studentmarklistpage"
             Title="Student mark list">
   

        <ContentPage.BindingContext>
            <vm:StudentViewModel />
        </ContentPage.BindingContext>

        <StackLayout Padding="16">

            <Label Text="Online Marksheet — Class XII"
               FontSize="18" FontAttributes="Bold"
               TextColor="#1565C0"
               HorizontalOptions="Center"
               Margin="0,0,0,16"/>

            <!-- Student Selector -->
            <Picker Title="Select Student"
                ItemsSource="{Binding Students}"
                ItemDisplayBinding="{Binding Name}"
                SelectedItem="{Binding SelectedStudent}"
                Margin="0,0,0,16"/>

            <!-- Marks Table Header -->
            <Grid ColumnDefinitions="*,80,80,60,50" BackgroundColor="#1565C0" Padding="8,4">
                <Label Grid.Column="0" Text="Subject"          TextColor="White" FontAttributes="Bold"/>
                <Label Grid.Column="1" Text="Obtained"         TextColor="White" FontAttributes="Bold"/>
                <Label Grid.Column="2" Text="Practical"        TextColor="White" FontAttributes="Bold"/>
                <Label Grid.Column="3" Text="Total"            TextColor="White" FontAttributes="Bold"/>
                <Label Grid.Column="4" Text="Grade"            TextColor="White" FontAttributes="Bold"/>
            </Grid>

            <!-- CollectionView for marks -->
            <CollectionView ItemsSource="{Binding SelectedStudent.Marks}"
                        HeightRequest="250">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,80,80,60,50"
                          Padding="8,6"
                          BackgroundColor="White">
                            <Label Grid.Column="0" Text="{Binding Subject}"/>
                            <Label Grid.Column="1" Text="{Binding ObtainedMarks}" HorizontalOptions="Center"/>
                            <Label Grid.Column="2" Text="{Binding PracticalMarks}" HorizontalOptions="Center"/>
                            <Label Grid.Column="3" Text="{Binding Total}"          HorizontalOptions="Center"/>
                            <Label Grid.Column="4" Text="{Binding Grade}"          HorizontalOptions="Center"
                               TextColor="#1565C0" FontAttributes="Bold"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Grand Total Row -->
            <Grid ColumnDefinitions="*,80,80,60,50"
              BackgroundColor="#E3F2FD" Padding="8,6">
                <Label Grid.Column="0" Text="Grand Total" FontAttributes="Bold"/>
                <Label Grid.Column="3"
                   Text="{Binding SelectedStudent.GrandTotal}"
                   FontAttributes="Bold" HorizontalOptions="Center"/>
            </Grid>

            <!-- Percentage & Result -->
            <StackLayout Orientation="Horizontal" Margin="0,12,0,0" Spacing="10">
                <Label Text="Percentage:" FontAttributes="Bold"/>
                <Label Text="{Binding SelectedStudent.Percentage, StringFormat='{0}%'}"/>
                <Label Text="Result:" FontAttributes="Bold" Margin="20,0,0,0"/>
                <Label Text="{Binding SelectedStudent.Result}" TextColor="Green" FontAttributes="Bold"/>
            </StackLayout>

        </StackLayout>
  </ContentPage>