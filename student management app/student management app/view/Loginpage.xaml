<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentManagementApp.ViewModels"
             x:Class="Student_Management_App.view.Loginpage"
             Title="Loginpage"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:LoginViewModel />
    </ContentPage.BindingContext>

    <Grid ColumnDefinitions="*,*">

        <!-- LEFT PANEL — Blue welcome section -->
        <StackLayout Grid.Column="0"
                     BackgroundColor="#1565C0"
                     VerticalOptions="Fill"
                     HorizontalOptions="Fill"
                     Padding="20"
                   >

            <Label Text="Welcome User!"
                   TextColor="White"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

            <Image Source="user_icon.png"
                   HeightRequest="100"
                   WidthRequest="100"
                   HorizontalOptions="Center"/>

            <Label Text="Developed by"
                   TextColor="#BBDEFB"
                   FontSize="12"
                   HorizontalOptions="Center"
                   Margin="0,30,0,0"/>
            <Label Text="Naveenkumar J"
                   TextColor="White"
                   FontSize="14"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>
        </StackLayout>

        <!-- RIGHT PANEL — Login form -->
        <StackLayout Grid.Column="1"
                     BackgroundColor="White"
                     Padding="30,40"
                     VerticalOptions="Center">

            <Label Text="School Management System"
                   TextColor="#1565C0"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

            <Label Text="Login Page"
                   FontSize="16"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

            <!-- Username -->
            <Label Text="User name" FontSize="13"/>
            <Entry Text="{Binding Username}"
                   Placeholder="Enter username"
                   Margin="0,0,0,10"/>

            <!-- Password -->
            <Label Text="Password" FontSize="13"/>
            <Entry Text="{Binding Password}"
                   IsPassword="True"
                   Placeholder="Enter password"
                   Margin="0,0,0,10"/>

            <!-- User Type Picker -->
            <Label Text="User Type" FontSize="13"/>
            <Picker ItemsSource="{Binding UserTypes}"
                    SelectedItem="{Binding UserType}"
                    Margin="0,0,0,20"/>

            <!-- Error message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   FontSize="12"
                   IsVisible="{Binding HasError}"
                   Margin="0,0,0,10"/>

            <!-- Buttons -->
            <StackLayout Orientation="Horizontal" Spacing="10">
                <Button Text="SUBMIT"
                        Command="{Binding LoginCommand}"
                        BackgroundColor="#1565C0"
                        TextColor="White"
                        HorizontalOptions="FillAndExpand"/>
                <Button Text="CLOSE"
                        Command="{Binding CloseCommand}"
                        BackgroundColor="#42A5F5"
                        TextColor="White"
                        HorizontalOptions="FillAndExpand"/>
            </StackLayout>

        </StackLayout>
    </Grid>
</ContentPage>